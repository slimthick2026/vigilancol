# VigilanCOL — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a GitHub

# ── REQUERIDA para actualización de candidatos con IA ────────────────────────
# Obtén tu key en: https://console.anthropic.com
# Costo aproximado: ~$0.01 por actualización (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── REQUERIDA para envío de alertas por email ────────────────────────────────
# Obtén tu key en: https://resend.com (gratis hasta 3.000 emails/mes)
# También debes verificar tu dominio en Resend
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OPCIONAL: Aumenta límite de requests a datos.gov.co ─────────────────────
# Sin token: 1.000 requests/hora por IP
# Con token: ilimitado
# Obtén uno gratis en: https://data.socrata.com/profile/edit/developer_settings
SOCRATA_TOKEN=tu_token_aqui
